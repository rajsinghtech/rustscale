+func TestAuditLogContract(t *testing.T) {
+	ctrl := &testcontrol.Server{}
+	ctrl.HTTPTestServer = httptest.NewUnstartedServer(ctrl)
+	ctrl.HTTPTestServer.Start()
+	t.Cleanup(ctrl.HTTPTestServer.Close)
+	ctx, cancel := context.WithTimeout(context.Background(), 15*time.Second)
+	defer cancel()
+	baseURL := ctrl.HTTPTestServer.URL
+	serverKey := must.Get(tsp.DiscoverServerKey(ctx, baseURL))
+	nodeKey := key.NewNode()
+	machineKey := key.NewMachine()
+	tc := must.Get(tsp.NewClient(tsp.ClientOpts{ServerURL: baseURL, MachineKey: machineKey}))
+	defer tc.Close()
+	tc.SetControlPublicKey(serverKey)
+	must.Get(tc.Register(ctx, tsp.RegisterOpts{NodeKey: nodeKey, Hostinfo: &tailcfg.Hostinfo{Hostname: "audit"}}))
+
+	nc := must.Get(ts2021.NewClient(ts2021.ClientOpts{
+		ServerURL: baseURL, PrivKey: machineKey, ServerPubKey: serverKey,
+		Dialer: tsdial.NewFromFuncForDebug(t.Logf, (&net.Dialer{}).DialContext),
+	}))
+	defer nc.Close()
+	validJSON := fmt.Sprintf(`{"Version":141,"NodeKey":"%s","Action":"DISCONNECT_NODE","Details":"public down"}`, nodeKey.Public())
+	validReq := must.Get(http.NewRequestWithContext(ctx, http.MethodPost, strings.Replace(baseURL+"/machine/audit-log", "http:", "https:", 1), strings.NewReader(validJSON)))
+	validReq.Header.Set("Content-Type", "application/json")
+	// No Ts-Lb header is needed: Noise machine authentication binds the node.
+	res := must.Get(nc.Do(validReq))
+	res.Body.Close()
+	if res.StatusCode != http.StatusOK {
+		t.Fatalf("valid audit status=%d", res.StatusCode)
+	}
+	stats := ctrl.AuditLogStats()
+	if stats.Accepted != 1 || stats.Rejected != 0 || stats.Action != tailcfg.AuditNodeDisconnect || stats.DetailsLen != len("public down") || stats.TimestampSet || len(stats.LastBodySHA256) != 64 {
+		t.Fatalf("unexpected zero-timestamp audit stats: %+v", stats)
+	}
+
+	res = must.Get(nc.Post(ctx, "/machine/audit-log", nodeKey.Public(), &tailcfg.AuditLogRequest{
+		Version: tailcfg.CurrentCapabilityVersion, NodeKey: nodeKey.Public(),
+		Action: tailcfg.AuditNodeDisconnect, Details: "public down", Timestamp: time.Unix(1, 0).UTC(),
+	}))
+	res.Body.Close()
+	if res.StatusCode != http.StatusOK {
+		t.Fatalf("timestamped audit status=%d", res.StatusCode)
+	}
+	stats = ctrl.AuditLogStats()
+	if stats.Accepted != 2 || stats.Rejected != 0 || !stats.TimestampSet {
+		t.Fatalf("unexpected timestamped audit stats: %+v", stats)
+	}
+
+	invalid := []struct {
+		name   string
+		body   string
+		status int
+		reason string
+	}{
+		{"unknown-field", validJSON[:len(validJSON)-1] + `,"Unexpected":true}`, http.StatusBadRequest, "json"},
+		{"malformed-timestamp", validJSON[:len(validJSON)-1] + `,"Timestamp":"not-a-time"}`, http.StatusBadRequest, "json"},
+		{"trailing-json", validJSON + ` {}`, http.StatusBadRequest, "trailing-json"},
+		{"wrong-version", strings.Replace(validJSON, `"Version":141`, `"Version":140`, 1), http.StatusBadRequest, "contract"},
+		{"unregistered-node", strings.Replace(validJSON, nodeKey.Public().String(), key.NewNode().Public().String(), 1), http.StatusForbidden, "node-binding"},
+	}
+	for i, tt := range invalid {
+		t.Run(tt.name, func(t *testing.T) {
+			req := must.Get(http.NewRequestWithContext(ctx, http.MethodPost, strings.Replace(baseURL+"/machine/audit-log", "http:", "https:", 1), strings.NewReader(tt.body)))
+			req.Header.Set("Content-Type", "application/json")
+			res := must.Get(nc.Do(req))
+			res.Body.Close()
+			if res.StatusCode != tt.status {
+				t.Fatalf("status=%d, want %d", res.StatusCode, tt.status)
+			}
+			stats := ctrl.AuditLogStats()
+			if stats.Accepted != 2 || stats.Rejected != uint64(i+1) || stats.LastError != tt.reason || len(stats.LastBodySHA256) != 64 {
+				t.Fatalf("unexpected rejected audit stats: %+v", stats)
+			}
+		})
+	}
+
+	wrongMethod := must.Get(http.NewRequestWithContext(ctx, http.MethodGet, strings.Replace(baseURL+"/machine/audit-log", "http:", "https:", 1), nil))
+	res = must.Get(nc.Do(wrongMethod))
+	res.Body.Close()
+	if res.StatusCode != http.StatusMethodNotAllowed {
+		t.Fatalf("wrong method status=%d", res.StatusCode)
+	}
+	stats = ctrl.AuditLogStats()
+	if stats.Accepted != 2 || stats.Rejected != uint64(len(invalid)+1) || stats.LastError != "method" {
+		t.Fatalf("unexpected method stats: %+v", stats)
+	}
+}
