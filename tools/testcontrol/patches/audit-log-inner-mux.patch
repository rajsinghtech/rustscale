+const maxAuditLogRequestBody = 64 << 10
+
+// AuditLogStats is the redacted audit-log state recorded by Server.
+// LastBodySHA256 is a deterministic signal for the last body without
+// retaining the body itself or its node key.
+type AuditLogStats struct {
+	Accepted       uint64
+	Rejected       uint64
+	Action         tailcfg.ClientAuditAction
+	DetailsLen     int
+	TimestampSet   bool
+	LastBodySHA256 string
+	LastError      string
+}
+
+// AuditLogStats returns a snapshot of audit-log processing state.
+func (s *Server) AuditLogStats() AuditLogStats {
+	s.auditMu.Lock()
+	defer s.auditMu.Unlock()
+	return s.auditLogStats
+}
+
+func (s *Server) recordAuditLog(body []byte, req *tailcfg.AuditLogRequest) {
+	s.auditMu.Lock()
+	defer s.auditMu.Unlock()
+	s.auditLogStats.Accepted++
+	s.auditLogStats.Action = req.Action
+	s.auditLogStats.DetailsLen = len(req.Details)
+	s.auditLogStats.TimestampSet = !req.Timestamp.IsZero()
+	s.auditLogStats.LastBodySHA256 = fmt.Sprintf("%x", sha256.Sum256(body))
+	s.auditLogStats.LastError = ""
+}
+
+func (s *Server) rejectAuditLog(body []byte, reason string) {
+	s.auditMu.Lock()
+	defer s.auditMu.Unlock()
+	s.auditLogStats.Rejected++
+	s.auditLogStats.LastBodySHA256 = fmt.Sprintf("%x", sha256.Sum256(body))
+	s.auditLogStats.LastError = reason
+}
