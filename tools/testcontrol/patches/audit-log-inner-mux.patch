+// serveAuditLog accepts only the pinned client audit contract over an
+// authenticated Noise connection. Unknown machine paths remain fail-closed.
+func (s *Server) serveAuditLog(w http.ResponseWriter, r *http.Request, mkey key.MachinePublic) {
+	if r.Method != http.MethodPost {
+		s.rejectAuditLog(nil, "method")
+		http.Error(w, "invalid audit log request", http.StatusMethodNotAllowed)
+		return
+	}
+	mediaType, _, err := mime.ParseMediaType(r.Header.Get("Content-Type"))
+	if err != nil || mediaType != "application/json" {
+		s.rejectAuditLog(nil, "content-type")
+		http.Error(w, "invalid audit log request", http.StatusBadRequest)
+		return
+	}
+	if r.ContentLength > maxAuditLogRequestBody {
+		s.rejectAuditLog(nil, "body-too-large")
+		http.Error(w, "invalid audit log request", http.StatusRequestEntityTooLarge)
+		return
+	}
+	body, err := io.ReadAll(http.MaxBytesReader(w, r.Body, maxAuditLogRequestBody))
+	if err != nil {
+		s.rejectAuditLog(body, "body-read")
+		http.Error(w, "invalid audit log request", http.StatusRequestEntityTooLarge)
+		return
+	}
+	defer r.Body.Close()
+
+	var req tailcfg.AuditLogRequest
+	dec := json.NewDecoder(bytes.NewReader(body))
+	dec.DisallowUnknownFields()
+	if err := dec.Decode(&req); err != nil {
+		s.rejectAuditLog(body, "json")
+		http.Error(w, "invalid audit log request", http.StatusBadRequest)
+		return
+	}
+	var extra any
+	if err := dec.Decode(&extra); err != io.EOF {
+		s.rejectAuditLog(body, "trailing-json")
+		http.Error(w, "invalid audit log request", http.StatusBadRequest)
+		return
+	}
+	if req.Version != tailcfg.CurrentCapabilityVersion ||
+		req.NodeKey.IsZero() ||
+		req.Action != tailcfg.AuditNodeDisconnect ||
+		strings.TrimSpace(req.Details) == "" {
+		s.rejectAuditLog(body, "contract")
+		http.Error(w, "invalid audit log request", http.StatusBadRequest)
+		return
+	}
+
+	s.mu.Lock()
+	node := s.nodes[req.NodeKey]
+	registered := node != nil && node.Machine == mkey
+	s.mu.Unlock()
+	if !registered {
+		s.rejectAuditLog(body, "node-binding")
+		http.Error(w, "invalid audit log request", http.StatusForbidden)
+		return
+	}
+
+	s.recordAuditLog(body, &req)
+	s.logf("accepted audit log action=%s details_len=%d timestamp=%t body_sha256=%x", req.Action, len(req.Details), !req.Timestamp.IsZero(), sha256.Sum256(body))
+	w.WriteHeader(http.StatusOK)
